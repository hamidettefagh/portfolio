{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/patterns/**",
              "components/primitives/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Newsreader|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Newsreader, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accent'] > JSXAttribute > JSXIdentifier[name!=/^(?:underline|ink|children|key|ref|className|style|children)$/]",
        "message": "<Accent> doesn't accept that prop. Declared props: underline, ink, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskAgent'] > JSXAttribute > JSXIdentifier[name!=/^(?:system|suggestions|focusEventName|key|ref|className|style|children)$/]",
        "message": "<AskAgent> doesn't accept that prop. Declared props: system, suggestions, focusEventName."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|target|arrow|disabled|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, target, arrow, disabled, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandMenu'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|openEventName|key|ref|className|style|children)$/]",
        "message": "<CommandMenu> doesn't accept that prop. Declared props: items, openEventName."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|href|copyable|key|ref|className|style|children)$/]",
        "message": "<ContactLink> doesn't accept that prop. Declared props: label, value, href, copyable."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExperienceItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:dates|role|org|note|placeholder|key|ref|className|style|children)$/]",
        "message": "<ExperienceItem> doesn't accept that prop. Declared props: dates, role, org, note, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:dot|accent|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: dot, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='dot'] > Literal[value!=/^(?:accent|live)$/]",
        "message": "<Eyebrow> dot must be one of 'accent' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|title|summary|org|href|onClick|key|ref|className|style|children)$/]",
        "message": "<ProjectRow> doesn't accept that prop. Declared props: index, title, summary, org, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rule'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|strong|key|ref|className|style|children)$/]",
        "message": "<Rule> doesn't accept that prop. Declared props: label, strong."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecsOverlay'] > JSXAttribute > JSXIdentifier[name!=/^(?:openEventName|key|ref|className|style|children)$/]",
        "message": "<SpecsOverlay> doesn't accept that prop. Declared props: openEventName."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|fill|accent)$/]",
        "message": "<Tag> variant must be one of 'outline' | 'fill' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|accent|external|children|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: href, accent, external, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|live|items|key|ref|className|style|children)$/]",
        "message": "<Ticker> doesn't accept that prop. Declared props: label, live, items."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
